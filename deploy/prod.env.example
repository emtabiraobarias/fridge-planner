# Fridge Planner — production secrets for docker-compose.prod.yml (single node, internal LAN).
#
# Copy to `.env` NEXT TO docker-compose.prod.yml on the host, fill in real values,
# then: chmod 600 .env && chown root:root .env
# NEVER commit the filled-in .env. This .example carries no real secrets.

# --- App image to run (set by the E2 deploy job; default is :latest) ---
APP_IMAGE=ghcr.io/emtabiraobarias/fridge-planner-client:latest

# --- MongoDB (root creds; the app also uses these) ---
MONGO_ROOT_USER=fridgeplanner
MONGO_ROOT_PASSWORD=change-me-long-random

# --- OIDC / Keycloak realm the app validates tokens against ---
OIDC_REALM=fridge-planner
OIDC_AUDIENCE=fridge-planner-app        # must match the token `aud` (Keycloak client/audience)

# --- Keycloak database (Postgres) ---
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me-long-random

# --- Keycloak first-boot admin (rotate after first login) ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-long-random

# --- Holodeck LLM credential (set ONE; OAuth token preferred) ---
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# --- NOT here: NEXT_PUBLIC_OIDC_* are BUILD args baked into the client image
#     (E2 build-push job), not runtime env. And AUTH_ALLOW_DEV must never be set. ---
