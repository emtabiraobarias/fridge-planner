{
  "name": "fridge-planner",
  "version": "4.0.0",
  "private": true,
  "workspaces": [
    "packages/client"
  ],
  "scripts": {
    "dev": "npm run client",
    "client": "npm -w packages/client run dev",
    "build": "npm -w packages/client run build",
    "test": "npm -w packages/client run test",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}' --max-warnings 0",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,css}'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --max-warnings 0 --fix",
      "prettier --write"
    ],
    "packages/*/src/**/*.css": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
