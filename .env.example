# ─── LLM Providers ────────────────────────────────────────────────────────────
# Primary: Anthropic Claude (used by holodeck meal-recommender agent)
ANTHROPIC_API_KEY=

# Fallback: OpenAI (use if Anthropic provider is unavailable in holodeck serve)
OPENAI_API_KEY=

# ─── Holodeck Sidecar ──────────────────────────────────────────────────────────
# URL for the holodeck agent REST API (served on port 8001 locally)
HOLODECK_URL=http://localhost:8001

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fridge-planner

# ─── Auth (OAuth 2.0 / OIDC) ──────────────────────────────────────────────────
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URI=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# ─── Redis (P2+, not required for P1 MVP) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
