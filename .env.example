# ─── LLM Providers ────────────────────────────────────────────────────────────
# Option A (preferred): Claude Code OAuth token — no API key required.
# Already set automatically inside a Claude Code session. Outside Claude Code,
# generate one with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Direct Anthropic API key (fallback if not using oauth_token).
ANTHROPIC_API_KEY=

# Fallback: OpenAI (use if Anthropic provider is unavailable in holodeck serve)
OPENAI_API_KEY=

# Ollama server used by the Holodeck evaluation model
OLLAMA_ENDPOINT=

# ─── Holodeck Sidecar ──────────────────────────────────────────────────────────
# URL for the holodeck agent REST API (served on port 8001 locally)
HOLODECK_URL=http://localhost:8001

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fridge-planner

# ─── Auth (OAuth 2.0 / OIDC) — spec 002 / Phase D ─────────────────────────────
# AUTH_MODE: "oidc" validates Bearer JWTs (signature via JWKS + iss/aud/exp);
# "dev" trusts the X-User-Id header (local dev + tests). Defaults to "dev" unless
# NODE_ENV=production (then "oidc" is required — the dev seam is refused in prod).
AUTH_MODE=dev
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URI=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# ─── Redis (P2+, not required for P1 MVP) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
