# ─── LLM Providers ────────────────────────────────────────────────────────────
# Required credential for both Holodeck agents (meal-recommender and
# feedback-collector) — both run on the OpenAI provider (Semantic Kernel backend).
OPENAI_API_KEY=

# Ollama server used by the Holodeck evaluation model
OLLAMA_ENDPOINT=

# ─── Holodeck Sidecar ──────────────────────────────────────────────────────────
# URL for the holodeck agent REST API (served on port 8001 locally)
HOLODECK_URL=http://localhost:8001

# URL for the feedback-collector Holodeck agent (spec 003 / Phase F — port 8002 locally).
# A second Holodeck container serves this second agent. When unset/unreachable the
# feedback chat endpoints return a 502 (drafts are preserved), so the rest of the app
# is unaffected.
FEEDBACK_AGENT_URL=http://localhost:8002

# ─── Recipe URL verification (Option A groundedness, meal-recommender) ────────
# The OpenAI-backed meal-recommender never authors a recipeUrl itself — a separate
# server-side step (src/server/services/recipe-verifier.ts) attaches one only when a
# real, existing recipe is found. Both are optional: if unset, meals are simply
# returned without a recipeUrl/imageUrl (no error, no fabrication).
#
# Primary: restricts search to the four approved recipe blogs (panlasangpinoy.com,
# recipetineats.com, kawalingpinoy.com, taste.com.au) via Brave Search's `site:` operator.
BRAVE_SEARCH_API_KEY=
# Fallback when the approved-domain search finds nothing: Spoonacular's own recipe
# database (not domain-restricted).
SPOONACULAR_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fridge-planner

# ─── Auth (OAuth 2.0 / OIDC) — spec 002 / Phase D ─────────────────────────────
# AUTH_MODE: "oidc" validates Bearer JWTs (signature via JWKS + iss/aud/exp);
# "dev" trusts the X-User-Id header (local dev + tests). Defaults to "dev" unless
# NODE_ENV=production (then "oidc" is required — the dev seam is refused in prod).
AUTH_MODE=dev
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URI=

# ─── Server ───────────────────────────────────────────────────────────────────
# Phase C-bis: the Next.js app (port 3000) is the whole backend — it serves the API
# from Route Handlers and talks to MongoDB + Holodeck directly. No separate Express
# service, so no PORT/CORS_ORIGIN/BACKEND_URL.
LOG_LEVEL=info
NODE_ENV=development

# ─── Redis (P2+, not required for P1 MVP) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
